# General
term = xterm-256color

# Appearance
theme = GitHub Dark Dimmed
font-size = 15
font-family = JetBrains Mono
font-family-bold = JetBrains Mono Bold
font-family-italic= JetBrains Mono Italic
font-family-bold-italic = JetBrains Mono Bold Italic

# Keybinds
keybind = super+x=unbind
keybind = super+v=unbind
keybind = super+c=text:\x03
keybind = super+shift+c=copy_to_clipboard
keybind = super+shift+v=paste_from_clipboard

